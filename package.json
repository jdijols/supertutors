{
  "name": "supertutors",
  "version": "0.1.0",
  "private": true,
  "description": "SuperTutors — Learn Fractions with Freddy. A scripted, conversational AI math tutor (Week 4 Gauntlet challenger project).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/generate-route-meta.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-voice": "node --env-file=.env.local scripts/generate-voice.ts",
    "og:generate": "node scripts/generate-og-image.mjs",
    "extract-dialogue": "echo 'TODO: implement dialogue extraction from Stately export into dialogue.json'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdijols/supertutors.git"
  },
  "homepage": "https://github.com/jdijols/supertutors#readme",
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/typography": "^0.5.19",
    "@xstate/react": "^6.1.0",
    "framer-motion": "^12.39.0",
    "howler": "^2.2.4",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.15.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "xstate": "^5.31.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@statelyai/inspect": "^0.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.13",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  }
}
